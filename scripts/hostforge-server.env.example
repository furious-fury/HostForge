# HostForge server environment (copy to /etc/hostforge/hostforge.env and fill values).
# File permissions: root:hostforge 640 recommended. Never commit real secrets.

# Required: management API bearer token (CLI and scripts use Authorization: Bearer)
HOSTFORGE_API_TOKEN=

# Required: HMAC key for signed UI session cookies (min 16 characters)
HOSTFORGE_SESSION_SECRET=

# Legacy fallback: GitHub webhook signing secret for org/repo-level webhooks that predate the GitHub App.
# HostForge verifies X-Hub-Signature-256 against the App's sealed webhook secret FIRST, then this value.
# You can leave it empty once every webhook is issued by the GitHub App created via Settings → GitHub App.
HOSTFORGE_WEBHOOK_SECRET=

# Required once you connect a GitHub App or store project PATs / SSH deploy keys:
# AES-256 key (base64 of 32 bytes: openssl rand -base64 32) that seals per-project env vars, PATs,
# SSH private keys, and the GitHub App private key + webhook secret at rest in SQLite.
# Without this, env, git-auth, ssh-key, and GitHub App endpoints return 503 and deploy cannot use stored encrypted secrets.
# Losing this key means all sealed values are unreadable — you must set a new key and re-enter them.
# HOSTFORGE_ENV_ENCRYPTION_KEY=

# Bind address. Production: keep on loopback and reverse-proxy or SSH-tunnel the UI/API.
HOSTFORGE_LISTEN=127.0.0.1:8080

# Persistent state (SQLite, worktrees, builds, logs)
HOSTFORGE_DATA_DIR=/var/lib/hostforge

# Per-IP webhook requests per minute (must be > 0)
HOSTFORGE_WEBHOOK_RATE_LIMIT_PER_MINUTE=60

# Optional: DNS hints in UI / domain APIs (auto-detect public IP if unset)
# HOSTFORGE_DNS_SERVER_IPV4=203.0.113.50
# HOSTFORGE_DNS_SERVER_IPV6=2001:db8::1
# HOSTFORGE_DNS_DETECT_URL=https://api.ipify.org
# HOSTFORGE_DNS_DETECT_IPV6_URL=https://api64.ipify.org
# HOSTFORGE_DNS_DETECT_TIMEOUT_MS=2500
# HOSTFORGE_DOMAIN_SYNC_AFTER_MUTATE=true

# Optional overrides
# HOSTFORGE_SESSION_COOKIE_NAME=hostforge_session
# HOSTFORGE_SESSION_TTL_MINUTES=720
# HOSTFORGE_SESSION_COOKIE_SECURE=true
# HOSTFORGE_WEBHOOK_BASE_PATH=/hooks/github
# HOSTFORGE_CADDY_ROOT_CONFIG=/etc/caddy/Caddyfile
# HOSTFORGE_SYNC_CADDY=true
# Snippet path (default: <HOSTFORGE_DATA_DIR>/caddy/hostforge.caddy). If systemd runs Caddy as user
# `caddy`, do NOT put the snippet only under /var/lib/hostforge or a 700 home — use e.g.:
#   HOSTFORGE_CADDY_GENERATED_PATH=/etc/caddy/hostforge.d/hostforge.caddy
# and in /etc/caddy/Caddyfile: import that path. Then fix permissions once:
#   sudo mkdir -p /etc/caddy/hostforge.d
#   sudo chown root:caddy /etc/caddy/hostforge.d && sudo chmod 2770 /etc/caddy/hostforge.d
#   sudo usermod -aG caddy hostforge   # operator who runs CLI sync; re-login
# New files in that dir pick up group `caddy` (setgid); ensure hostforge.caddy is g+r (e.g. 0640).

# Optional: mirror leaf cert hints into SQLite (domains.last_cert_message / cert_checked_at). 0 = disabled.
# HOSTFORGE_CADDY_CERT_POLL_INTERVAL_SEC=300
# HOSTFORGE_CADDY_ADMIN=http://127.0.0.1:2019
# Caddy storage root for PEM scans (Debian package often uses /var/lib/caddy; user installs may use ~/.local/share/caddy)
# HOSTFORGE_CADDY_STORAGE_ROOT=/var/lib/caddy
